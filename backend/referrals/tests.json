{
  "tests": [
    {"name": "my_code without auth", "method": "GET", "path": "/?action=my_code", "expectedStatus": 401, "expectedBody": {"error": "string"}, "bodyMatcher": "partial"},
    {"name": "use_code without auth", "method": "POST", "path": "/?action=use_code", "body": {"code": "ABCD"}, "expectedStatus": 401, "expectedBody": {"error": "string"}, "bodyMatcher": "partial"},
    {"name": "invited_list without auth", "method": "GET", "path": "/?action=invited_list", "expectedStatus": 401, "expectedBody": {"error": "string"}, "bodyMatcher": "partial"},
    {"name": "unknown action", "method": "GET", "path": "/?action=unknown", "expectedStatus": 404, "expectedBody": {"error": "string"}, "bodyMatcher": "partial"},
    {"name": "promo_track share vk", "method": "POST", "path": "/?action=promo_track", "body": {"promo": "dobro", "event": "share", "channel": "vk"}, "expectedStatus": 200, "expectedBody": {"ok": true}, "bodyMatcher": "partial"},
    {"name": "promo_track visit", "method": "POST", "path": "/?action=promo_track", "body": {"promo": "dobro", "event": "visit", "channel": "vk"}, "expectedStatus": 200, "expectedBody": {"ok": true}, "bodyMatcher": "partial"},
    {"name": "promo_track invalid event", "method": "POST", "path": "/?action=promo_track", "body": {"event": "bad"}, "expectedStatus": 400, "expectedBody": {"error": "string"}, "bodyMatcher": "partial"},
    {"name": "promo_stats", "method": "GET", "path": "/?action=promo_stats&promo=dobro", "expectedStatus": 200, "expectedBody": {"promo": "string"}, "bodyMatcher": "partial"}
  ]
}