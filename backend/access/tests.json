{
  "tests": [
    {
      "name": "OPTIONS CORS",
      "method": "OPTIONS",
      "path": "/",
      "expectedStatus": 200
    },
    {
      "name": "Check без токена - анонимный гость",
      "method": "GET",
      "path": "/?action=check&course_id=1",
      "expectedStatus": 200,
      "expectedBody": {"authenticated": false, "has_subscription": false},
      "bodyMatcher": "partial"
    },
    {
      "name": "Check с невалидным токеном - тоже гость",
      "method": "GET",
      "path": "/?action=check",
      "headers": {"X-Auth-Token": "invalid-token-xxx"},
      "expectedStatus": 200,
      "expectedBody": {"authenticated": false},
      "bodyMatcher": "partial"
    },
    {
      "name": "Buy курса без токена - 401 (требуется вход)",
      "method": "POST",
      "path": "/?action=buy_course",
      "body": {"course_id": 1, "grade": "ege", "return_url": "https://example.com/ok"},
      "expectedStatus": 401,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Buy подписки без токена - 401 (требуется вход)",
      "method": "POST",
      "path": "/?action=buy_subscription",
      "body": {"plan_id": "pro", "return_url": "https://example.com/ok"},
      "expectedStatus": 401,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "validate_coupon без токена - 401",
      "method": "POST",
      "path": "/?action=validate_coupon",
      "body": {"coupon_code": "ZN-TEST-CODE", "amount_rub": 1290},
      "expectedStatus": 401,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "sync_payment без токена - 401",
      "method": "POST",
      "path": "/?action=sync_payment",
      "body": {},
      "expectedStatus": 401,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Unknown action - 404",
      "method": "GET",
      "path": "/?action=unknown",
      "expectedStatus": 404
    }
  ]
}