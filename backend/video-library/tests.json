{
  "tests": [
    {
      "name": "OPTIONS preflight",
      "method": "OPTIONS",
      "path": "/",
      "expectedStatus": 200
    },
    {
      "name": "Unknown action returns 400",
      "method": "POST",
      "path": "/",
      "body": {"action": "nope"},
      "expectedStatus": 400
    },
    {
      "name": "Public list works without auth",
      "method": "GET",
      "path": "/?action=list",
      "expectedStatus": 200
    },
    {
      "name": "Save without auth returns 401",
      "method": "POST",
      "path": "/?action=save",
      "body": {"action": "save", "title": "Тест"},
      "expectedStatus": 401
    },
    {
      "name": "Mine list without auth returns 401",
      "method": "GET",
      "path": "/?action=list&mine=1",
      "expectedStatus": 401
    }
  ]
}