{
  "tests": [
    {
      "name": "CORS preflight",
      "method": "OPTIONS",
      "path": "/",
      "expectedStatus": 200
    },
    {
      "name": "Неизвестное действие",
      "method": "GET",
      "path": "/",
      "expectedStatus": 404,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Submit без имени возвращает ошибку",
      "method": "POST",
      "path": "/?action=submit",
      "body": {"contact_email": "test@example.com"},
      "expectedStatus": 400,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Submit без контактов возвращает ошибку",
      "method": "POST",
      "path": "/?action=submit",
      "body": {"contact_name": "Иван"},
      "expectedStatus": 400,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Список заявок без пина запрещён",
      "method": "GET",
      "path": "/?action=leads_list",
      "expectedStatus": 403,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    }
  ]
}
