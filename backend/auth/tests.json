{
  "tests": [
    {
      "name": "OPTIONS возвращает CORS",
      "method": "OPTIONS",
      "path": "/",
      "expectedStatus": 200
    },
    {
      "name": "Unknown action returns 404",
      "method": "GET",
      "path": "/?action=unknown",
      "expectedStatus": 404
    },
    {
      "name": "Login без тела возвращает 400",
      "method": "POST",
      "path": "/?action=login",
      "body": {},
      "expectedStatus": 400,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Register с невалидным email",
      "method": "POST",
      "path": "/?action=register",
      "body": {"email": "not-an-email", "password": "12345678"},
      "expectedStatus": 400,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Register с коротким паролем",
      "method": "POST",
      "path": "/?action=register",
      "body": {"email": "test@example.com", "password": "1"},
      "expectedStatus": 400,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Login с несуществующим email",
      "method": "POST",
      "path": "/?action=login",
      "body": {"email": "nobody@example.com", "password": "wrongpass123"},
      "expectedStatus": 401,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Me без токена возвращает 401",
      "method": "GET",
      "path": "/?action=me",
      "expectedStatus": 401,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Yandex callback без кода возвращает 400",
      "method": "POST",
      "path": "/?action=yandex-callback",
      "body": {},
      "expectedStatus": 400,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    }
  ]
}