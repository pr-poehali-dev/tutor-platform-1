{
  "tests": [
    {
      "name": "OPTIONS preflight",
      "method": "OPTIONS",
      "path": "/",
      "expectedStatus": 200
    },
    {
      "name": "Unknown action returns 400",
      "method": "POST",
      "path": "/",
      "body": {"action": "unknown_action"},
      "expectedStatus": 400
    },
    {
      "name": "Subjects list works",
      "method": "POST",
      "path": "/",
      "body": {"action": "subjects"},
      "expectedStatus": 200
    },
    {
      "name": "generate_lesson требует topic",
      "method": "POST",
      "path": "/",
      "body": {"action": "generate_lesson", "subject": "math"},
      "expectedStatus": 400
    }
  ]
}