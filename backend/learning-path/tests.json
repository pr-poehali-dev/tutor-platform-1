{
  "tests": [
    {
      "name": "OPTIONS preflight",
      "method": "OPTIONS",
      "path": "/",
      "expectedStatus": 200
    },
    {
      "name": "Unknown action returns 400",
      "method": "POST",
      "path": "/",
      "body": {"action": "unknown_action"},
      "expectedStatus": 400
    },
    {
      "name": "Subjects list works",
      "method": "POST",
      "path": "/",
      "body": {"action": "subjects"},
      "expectedStatus": 200
    },
    {
      "name": "generate_lesson требует topic",
      "method": "POST",
      "path": "/",
      "body": {"action": "generate_lesson", "subject": "math"},
      "expectedStatus": 400
    },
    {
      "name": "generate_lesson_tasks требует topic",
      "method": "POST",
      "path": "/",
      "body": {"action": "generate_lesson_tasks", "subject": "math"},
      "expectedStatus": 400
    },
    {
      "name": "ЕГЭ математика задачи DUMP",
      "method": "POST",
      "path": "/",
      "body": {"action": "generate_lesson_tasks", "subject": "math", "topic": "Производные", "grade": "ege", "difficulty": "сложный", "n": 5},
      "expectedStatus": 200,
      "expectedBody": {"__dump__": "show"},
      "bodyMatcher": "partial"
    },
    {
      "name": "ОГЭ математика задачи",
      "method": "POST",
      "path": "/",
      "body": {"action": "generate_lesson_tasks", "subject": "math", "topic": "Реальная математика", "grade": "oge", "difficulty": "средний", "n": 5},
      "expectedStatus": 200,
      "bodyMatcher": "partial"
    }
  ]
}