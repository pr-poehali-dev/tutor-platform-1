{
  "tests": [
    {"name": "reviews list public ok", "method": "GET", "path": "/?action=reviews_list", "expectedStatus": 200, "expectedBody": {"items": []}, "bodyMatcher": "partial"},
    {"name": "review_submit without auth", "method": "POST", "path": "/?action=review_submit", "body": {"author_name":"Иван","author_role":"student","rating":5,"text":"Отличная платформа, помогла подготовиться к ЕГЭ."}, "expectedStatus": 401, "expectedBody": {"error": "string"}, "bodyMatcher": "partial"},
    {"name": "feedback empty name", "method": "POST", "path": "/?action=feedback_submit", "body": {"contact_name":"","message":"test","contact_email":"a@b.ru"}, "expectedStatus": 400, "expectedBody": {"error": "string"}, "bodyMatcher": "partial"},
    {"name": "feedback no contacts", "method": "POST", "path": "/?action=feedback_submit", "body": {"contact_name":"Алексей","message":"Хочу узнать тарифы подробнее, помогите пожалуйста."}, "expectedStatus": 400, "expectedBody": {"error": "string"}, "bodyMatcher": "partial"},
    {"name": "feedback valid", "method": "POST", "path": "/?action=feedback_submit", "body": {"contact_name":"Алексей","contact_email":"test@example.com","subject":"general","message":"Хочу узнать тарифы подробнее, помогите пожалуйста."}, "expectedStatus": 200, "expectedBody": {"ok": true}, "bodyMatcher": "partial"},
    {"name": "partner_lead empty name", "method": "POST", "path": "/?action=partner_lead", "body": {"contact_name":"","contact_email":"school@example.com"}, "expectedStatus": 400, "expectedBody": {"error": "string"}, "bodyMatcher": "partial"},
    {"name": "partner_lead no contacts", "method": "POST", "path": "/?action=partner_lead", "body": {"contact_name":"Мария","company":"Школа Успех"}, "expectedStatus": 400, "expectedBody": {"error": "string"}, "bodyMatcher": "partial"},
    {"name": "partner_lead valid", "method": "POST", "path": "/?action=partner_lead", "body": {"contact_name":"Мария","contact_email":"school@example.com","company":"Школа Успех","audience_type":"school","topic":"Английский для детей","students_est":"100-500","plan_interest":"pro","message":"Хотим перенести школу на вашу платформу."}, "expectedStatus": 200, "expectedBody": {"ok": true}, "bodyMatcher": "partial"},
    {"name": "leads_list without pin", "method": "GET", "path": "/?action=leads_list", "expectedStatus": 403, "expectedBody": {"error": "string"}, "bodyMatcher": "partial"},
    {"name": "lead_update without pin", "method": "POST", "path": "/?action=lead_update", "body": {"id":1,"status":"won"}, "expectedStatus": 403, "expectedBody": {"error": "string"}, "bodyMatcher": "partial"},
    {"name": "invite_grant without pin", "method": "POST", "path": "/?action=invite_grant", "body": {"email":"a@b.ru"}, "expectedStatus": 403, "expectedBody": {"error": "string"}, "bodyMatcher": "partial"},
    {"name": "invites_list without pin", "method": "GET", "path": "/?action=invites_list", "expectedStatus": 403, "expectedBody": {"error": "string"}, "bodyMatcher": "partial"},
    {"name": "payouts_summary without pin", "method": "GET", "path": "/?action=payouts_summary", "expectedStatus": 403, "expectedBody": {"error": "string"}, "bodyMatcher": "partial"},
    {"name": "payout_create without pin", "method": "POST", "path": "/?action=payout_create", "body": {"school_id":1,"amount_kopecks":10000}, "expectedStatus": 403, "expectedBody": {"error": "string"}, "bodyMatcher": "partial"},
    {"name": "payouts_history without pin", "method": "GET", "path": "/?action=payouts_history", "expectedStatus": 403, "expectedBody": {"error": "string"}, "bodyMatcher": "partial"},
    {"name": "unknown action", "method": "GET", "path": "/?action=unknown", "expectedStatus": 404, "expectedBody": {"error": "string"}, "bodyMatcher": "partial"}
  ]
