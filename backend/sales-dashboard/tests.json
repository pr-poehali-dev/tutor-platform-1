{
  "tests": [
    {
      "name": "OPTIONS preflight",
      "method": "OPTIONS",
      "path": "/",
      "expectedStatus": 200
    },
    {
      "name": "Overview без PIN — 403",
      "method": "GET",
      "path": "/?action=overview",
      "expectedStatus": 403,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Overview неверный PIN — 403",
      "method": "GET",
      "path": "/?action=overview",
      "headers": {"X-Admin-Pin": "wrong-pin-xyz"},
      "expectedStatus": 403
    },
    {
      "name": "Funnel неверный PIN — 403",
      "method": "GET",
      "path": "/?action=funnel",
      "headers": {"X-Admin-Pin": "wrong-pin-xyz"},
      "expectedStatus": 403
    },
    {
      "name": "Customers неверный PIN — 403",
      "method": "GET",
      "path": "/?action=customers",
      "headers": {"X-Admin-Pin": "wrong-pin-xyz"},
      "expectedStatus": 403
    },
    {
      "name": "Customer неверный PIN — 403",
      "method": "GET",
      "path": "/?action=customer&id=1",
      "headers": {"X-Admin-Pin": "wrong-pin-xyz"},
      "expectedStatus": 403
    }
  ]
}
