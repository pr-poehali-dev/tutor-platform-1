{
  "tests": [
    {
      "name": "OPTIONS preflight",
      "method": "OPTIONS",
      "path": "/",
      "expectedStatus": 200
    },
    {
      "name": "Без PIN — 403",
      "method": "GET",
      "path": "/?action=overview",
      "expectedStatus": 403,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Неверный PIN — 403",
      "method": "GET",
      "path": "/?action=overview",
      "headers": {"X-Admin-Pin": "wrong"},
      "expectedStatus": 403
    },
    {
      "name": "Overview с правильным PIN",
      "method": "GET",
      "path": "/?action=overview&days=30",
      "headers": {"X-Admin-Pin": "7777"},
      "expectedStatus": 200,
      "expectedBody": {"period_days": 30},
      "bodyMatcher": "partial"
    },
    {
      "name": "Funnel с правильным PIN",
      "method": "GET",
      "path": "/?action=funnel&days=30",
      "headers": {"X-Admin-Pin": "7777"},
      "expectedStatus": 200,
      "expectedBody": {"period_days": 30},
      "bodyMatcher": "partial"
    },
    {
      "name": "Customers с правильным PIN",
      "method": "GET",
      "path": "/?action=customers&limit=10",
      "headers": {"X-Admin-Pin": "7777"},
      "expectedStatus": 200,
      "expectedBody": {"limit": 10},
      "bodyMatcher": "partial"
    }
  ]
}