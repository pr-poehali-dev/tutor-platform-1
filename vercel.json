{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    {
      "source": "/share/:page",
      "destination": "/api/share?page=:page"
    }
  ],
  "crons": [
    {
      "path": "/api/cron-feed",
      "schedule": "0 */6 * * *"
    },
    {
      "path": "/api/cron-keepalive",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron-health",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron-backup",
      "schedule": "0 3 * * *"
    }
  ]
}